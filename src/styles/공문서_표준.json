      "numbering": "I, II, III",
      "font": "HCR Batang",
      "size_pt": 15,
      "bold": true,
      "align": "left",
      "indent_left_hwpunit": 1000,
      "space_before_hwpunit": 600,
      "space_after_hwpunit": 300,
      "line_height_percent": 160
    },
    "heading2": {
      "numbering": "1, 2, 3",
      "font": "HCR Batang",
      "size_pt": 13,
      "bold": true,
      "align": "left",
      "indent_left_hwpunit": 1500,
      "space_before_hwpunit": 400,
      "space_after_hwpunit": 200,
      "line_height_percent": 160
    },
    "heading3": {
      "numbering": "가, 나, 다",
      "font": "HCR Batang",
      "size_pt": 12,
      "bold": true,
      "align": "left",
      "indent_left_hwpunit": 2000,
      "space_before_hwpunit": 200,
      "space_after_hwpunit": 100,
      "line_height_percent": 160
    },
    "heading4": {
      "numbering": "1), 2), 3)",
      "font": "HCR Batang",
      "size_pt": 11,
      "bold": false,
      "align": "left",
      "indent_left_hwpunit": 3000,
      "space_before_hwpunit": 100,
      "space_after_hwpunit": 50,
      "line_height_percent": 160
